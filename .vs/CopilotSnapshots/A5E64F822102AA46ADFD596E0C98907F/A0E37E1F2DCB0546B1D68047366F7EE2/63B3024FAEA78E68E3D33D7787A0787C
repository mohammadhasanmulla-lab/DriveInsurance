@{
    Layout = null;
    var title = ViewBag.Title ?? "DriveSure Insurance";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link href="~/css/site.css" rel="stylesheet" />

    @RenderSection("Head", required: false)
</head>
<body class="bg-light text-dark" style="font-family: 'Poppins', sans-serif;">

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="~/">
                <div class="brand-mark rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-2" style="width:40px;height:40px">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <div class="ms-1">
                    <strong>DriveSure</strong>
                    <div class="small text-muted" style="line-height:1">@ViewBag.Tagline ?? "Insurance Claim Processing"</div>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" href="~/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                    <li class="nav-item"><a class="btn btn-outline-primary ms-2" href="~/Home/Login">Login</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="pt-5 mt-4">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-top mt-5">
        <div class="container py-4">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <strong>DriveSure Insurance</strong> &copy; @DateTime.Now.Year. All rights reserved.
                </div>
                <div class="col-md-6 text-center text-md-end text-muted small">
                    <a class="text-decoration-none text-muted me-3" href="#">Privacy</a>
                    <a class="text-decoration-none text-muted me-3" href="#">Terms</a>
                    <a class="text-decoration-none text-muted" href="#">Support</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS & dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Chart.js for admin dummy charts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
