@{
	ViewBag.Title = "Login - DriveSure";
}
<div class="d-flex align-items-center justify-content-center" style="min-height:75vh;">
	<div class="row w-100 justify-content-center">
		<div class="col-md-8 col-lg-6">
			<div class="card overflow-hidden shadow-lg">
				<div class="row g-0">
					<div class="col-md-5 d-none d-md-block" style="background: linear-gradient(180deg,#2563EB,#1E3A8A); color:white;">
						<div class="p-4 text-center">
							<h3 class="fw-bold">Welcome Back</h3>
							<p class="small">Secure access to claims & dashboards</p>
							<i class="fa-solid fa-shield-halved fa-3x mt-3"></i>
						</div>
					</div>
					<div class="col-md-7">
						<div class="card-body p-4">
							<h5 class="card-title mb-3">Login</h5>
							<form>
								<div class="mb-3">
									<label class="form-label">Email</label>
									<input type="email" class="form-control" placeholder="your@company.com" />
								</div>
								<div class="mb-3">
									<label class="form-label">Password</label>
									<input type="password" class="form-control" placeholder="Password" />
								</div>
								<div class="d-flex justify-content-between align-items-center">
									<div>
										<input type="checkbox" id="remember" /> <label for="remember" class="small">Remember me</label>
									</div>
									<a href="#" class="small">Forgot?</a>
								</div>
								<div class="mt-4">
									<button class="btn btn-primary w-100">Sign In</button>
								</div>
								<div class="text-center mt-3 small text-muted">
									New to DriveSure? <a href="/Home/Register">Create account</a>
								</div>
							</form>
						</div>
					</div>
				</div>
			</div>
			<div class="text-center mt-3 text-muted small">
				<i class="fa-solid fa-lock me-1"></i> Securely powered by DriveSure
			</div>
		</div>
	</div>
</div>