@{
	ViewBag.Title = "Login - DriveSure";
}
<div class="d-flex align-items-center justify-content-center" style="min-height:calc(100vh - 80px); margin-top:80px;">
	<div class="row w-100 justify-content-center px-3">
		<div class="col-md-8 col-lg-6">
			<!-- Error Alert -->
			@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
			{
				<div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
					<i class="fa-solid fa-circle-exclamation me-2"></i>
					<strong>Login Failed</strong>
					<br />
					@ViewBag.ErrorMessage
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}

			<!-- Success Alert -->
			@if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
			{
				<div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
					<i class="fa-solid fa-circle-check me-2"></i>
					@ViewBag.SuccessMessage
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}

			<div class="card overflow-hidden shadow-lg">
				<div class="row g-0">
					<div class="col-md-5 d-none d-md-block" style="background: linear-gradient(180deg,#2563EB,#1E3A8A); color:white;">
						<div class="p-4 text-center d-flex flex-column justify-content-center h-100">
							<h3 class="fw-bold">Welcome Back</h3>
							<p class="small">Secure access to claims & dashboards</p>
							<i class="fa-solid fa-shield-halved fa-3x mt-3"></i>
							<hr class="bg-white opacity-25 my-4" />
							<div class="small">
								<p class="mb-2"><strong>Demo Credentials:</strong></p>
								<p class="mb-1">Admin: admin@company.com</p>
								<p>Password: Admin@123</p>
							</div>
						</div>
					</div>
					<div class="col-md-7">
						<div class="card-body p-4">
							<h5 class="card-title mb-4">Login to Your Account</h5>
							<form method="post" action="/Home/Login">
								<div class="mb-3">
									<label class="form-label fw-semibold">Email Address</label>
									<input type="email" class="form-control" name="email" placeholder="your@company.com" required />
									<small class="text-muted">Enter your email address</small>
								</div>
								<div class="mb-3">
									<label class="form-label fw-semibold">Password</label>
									<input type="password" class="form-control" name="password" placeholder="Password" required />
									<small class="text-muted">Enter your password</small>
								</div>
								<div class="d-flex justify-content-between align-items-center mb-4">
									<div>
										<input type="checkbox" id="remember" name="remember" /> 
										<label for="remember" class="small">Remember me</label>
									</div>
									<a href="#" class="small text-primary">Forgot password?</a>
								</div>
								<div class="mt-4">
									<button type="submit" class="btn btn-primary w-100 py-2">
										<i class="fa-solid fa-sign-in-alt me-2"></i>Sign In
									</button>
								</div>
								<div class="text-center mt-3 small text-muted">
									New to DriveSure? <a href="/Home/Register" class="text-primary">Create account</a>
								</div>
							</form>
						</div>
					</div>
				</div>
			</div>

			<!-- Demo Credentials Info Card (Mobile) -->
			<div class="card border-0 shadow-sm mt-3 d-md-none">
				<div class="card-body p-3">
					<h6 class="fw-bold mb-2">
						<i class="fa-solid fa-circle-info text-info me-2"></i>Demo Credentials
					</h6>
					<small class="text-muted d-block mb-2">
						<strong>Admin:</strong> admin@company.com / Admin@123
					</small>
					<small class="text-muted">
						<strong>User:</strong> jane@company.com / Jane@123
					</small>
				</div>
			</div>

			<div class="text-center mt-3 text-muted small">
				<i class="fa-solid fa-lock me-1"></i> Securely powered by DriveSure Insurance
			</div>
		</div>
	</div>
</div>
