@{
	ViewBag.Title = "Compliance Dashboard - DriveSure";
	ViewBag.Active = "Dashboard";
	ViewBag.UserName = "Compliance Analyst";
}
<div class="row g-3">
	<div class="col-lg-3 d-none d-lg-block">
		@await Html.PartialAsync("_Sidebar")
	</div>
	<div class="col-lg-9">
		<div class="d-flex justify-content-between align-items-center mb-3">
			<div>
				<h4 class="mb-0">Compliance & Risk</h4>
				<div class="small text-muted">Monitor fraud and risk assessments</div>
			</div>
			<div>
				<button class="btn btn-outline-primary me-2">Run Checks</button>
				<button class="btn btn-primary">Export Report</button>
			</div>
		</div>

n        <div class="row g-3 mb-3">
			<div class="col-md-4">
				<div class="card shadow-sm text-center">
					<div class="card-body">
						<div class="h1 text-success"><i class="fa-solid fa-circle-check"></i></div>
						<div class="fw-bold">Low Risk</div>
						<div class="small text-muted">120 claims</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm text-center">
					<div class="card-body">
						<div class="h1 text-warning"><i class="fa-solid fa-triangle-exclamation"></i></div>
						<div class="fw-bold">Medium Risk</div>
						<div class="small text-muted">34 claims</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm text-center">
					<div class="card-body">
						<div class="h1 text-danger"><i class="fa-solid fa-skull-crossbones"></i></div>
						<div class="fw-bold">High Risk</div>
						<div class="small text-muted">8 claims</div>
					</div>
				</div>
			</div>
		</div>

n        <div class="card shadow-sm">
			<div class="card-body">
				<h6>Claims with Risk Scores</h6>
				<div class="table-responsive">
					<table class="table">
						<thead class="table-light">
							<tr>
								<th>Claim ID</th>
								<th>Customer</th>
								<th>Amount</th>
								<th>Risk Score</th>
								<th>Action</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td>CLM-10321</td>
								<td>John Smith</td>
								<td>$4,200</td>
								<td><span class="badge bg-danger">82</span></td>
								<td><button class="btn btn-sm btn-outline-danger">Escalate</button></td>
							</tr>
							<tr>
								<td>CLM-10288</td>
								<td>Olivia Brown</td>
								<td>$1,100</td>
								<td><span class="badge bg-warning text-dark">45</span></td>
								<td><button class="btn btn-sm btn-outline-primary">Review</button></td>
							</tr>
						</tbody>
					</table>
				</div>
			</div>
		</div>

n    </div>
</div>