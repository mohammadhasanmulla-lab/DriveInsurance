@model MyProject.Models.FraudCheckEntity?
@{
    ViewBag.Title = "Fraud Score - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int claimId = ViewBag.ClaimId;
    var role = Context.Session.GetString("UserRole") ?? "";
}

<div class="container py-4" style="max-width:680px">
    <div class="mb-4">
        <a href="/Claim/GetClaimDetails/@claimId" class="text-decoration-none text-muted small"><i class="fa-solid fa-arrow-left me-1"></i>Back to Claim #CLM-@claimId.ToString("D5")</a>
        <h4 class="fw-bold mt-2"><i class="fa-solid fa-shield-halved me-2 text-warning"></i>Fraud & Compliance Check</h4>
    </div>

    @if (TempData["Success"] != null)
    { <div class="alert alert-success alert-dismissible fade show"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Error"] != null)
    { <div class="alert alert-danger alert-dismissible fade show"><i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

    @if (role is "ClaimsOfficer" or "ComplianceOfficer" or "Admin")
    {
        <form asp-action="RunFraudCheck" asp-controller="Fraud" method="post" class="mb-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="claimId" value="@claimId" />
            <button type="submit" class="btn btn-warning">
                <i class="fa-solid fa-wand-magic-sparkles me-1"></i>
                @(Model == null ? "Run Fraud Check" : "Re-run Fraud Check")
            </button>
        </form>
    }

    @if (Model == null)
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5 text-muted">
                <i class="fa-solid fa-shield-halved fa-3x mb-3 d-block"></i>
                No fraud check has been run for this claim yet.
            </div>
        </div>
    }
    else
    {
        var riskColor = Model.RiskFlag switch { "HIGH" => "danger", "MEDIUM" => "warning", _ => "success" };
        var riskIcon  = Model.RiskFlag switch { "HIGH" => "fa-skull-crossbones", "MEDIUM" => "fa-triangle-exclamation", _ => "fa-circle-check" };
        var scoreColor = Model.FraudScore > 60 ? "danger" : Model.FraudScore > 30 ? "warning" : "success";

        <div class="card shadow-sm mb-3 border-@riskColor border-start border-4">
            <div class="card-body">
                <div class="row align-items-center g-3">
                    <div class="col-auto">
                        <div class="rounded-circle bg-@riskColor bg-opacity-10 text-@riskColor d-flex align-items-center justify-content-center" style="width:64px;height:64px;font-size:1.6rem">
                            <i class="fa-solid @riskIcon"></i>
                        </div>
                    </div>
                    <div class="col">
                        <div class="text-muted small">Risk Level</div>
                        <div class="h3 fw-bold text-@riskColor mb-0">@Model.RiskFlag</div>
                        <div class="text-muted small">Check run @Model.CheckDate.ToString("MMMM dd, yyyy HH:mm")</div>
                    </div>
                    <div class="col-auto text-end">
                        <div class="text-muted small">Fraud Score</div>
                        <div class="h2 fw-bold text-@scoreColor mb-0">@Model.FraudScore <span class="fs-6 text-muted fw-normal">/ 100</span></div>
                    </div>
                </div>

                <div class="mt-3">
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>Low</span><span>Medium</span><span>High</span>
                    </div>
                    <div class="progress" style="height:12px">
                        <div class="progress-bar bg-@scoreColor" role="progressbar" style="width:@Model.FraudScore%" aria-valuenow="@Model.FraudScore" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="d-flex justify-content-between small text-muted mt-1">
                        <span>0</span><span>30</span><span>60</span><span>100</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white py-2">
                <span class="fw-semibold small"><i class="fa-solid fa-list-check me-1 text-muted"></i>Triggered Rules</span>
            </div>
            <div class="card-body">
                @if (string.IsNullOrWhiteSpace(Model.Notes) || Model.Notes == "No risk indicators detected.")
                {
                    <div class="text-success small"><i class="fa-solid fa-circle-check me-1"></i>No risk indicators detected.</div>
                }
                else
                {
                    foreach (var note in Model.Notes!.Split('|', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <div class="d-flex align-items-start gap-2 mb-2">
                            <i class="fa-solid fa-circle-dot text-warning mt-1"></i>
                            <span class="small">@note.Trim()</span>
                        </div>
                    }
                }
            </div>
        </div>

        @if (Model.RiskFlag != "HIGH" && (role is "ClaimsOfficer" or "Admin"))
        {
            <div class="mt-3">
                <a href="/Settlement/Details/@claimId" class="btn btn-outline-success btn-sm">
                    <i class="fa-solid fa-arrow-right me-1"></i>Proceed to Settlement
                </a>
            </div>
        }
    }
</div>
