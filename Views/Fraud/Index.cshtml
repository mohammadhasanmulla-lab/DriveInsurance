@model List<MyProject.Models.FraudCheckEntity>
@{
    ViewBag.Title = "Fraud Checks - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h4 class="fw-bold"><i class="fa-solid fa-shield-halved me-2 text-warning"></i>Fraud & Compliance Checks</h4>
        <div class="text-muted small">Rule-based fraud scoring results for all claims</div>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm"><div class="card-body text-center py-5 text-muted"><i class="fa-solid fa-shield-halved fa-3x mb-3 d-block"></i>No fraud checks have been run yet.</div></div>
    }
    else
    {
        <!-- Summary cards -->
        <div class="row g-3 mb-4">
            @{
                var low    = Model.Count(f => f.RiskFlag == "LOW");
                var medium = Model.Count(f => f.RiskFlag == "MEDIUM");
                var high   = Model.Count(f => f.RiskFlag == "HIGH");
            }
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-success bg-opacity-10">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="fs-1 text-success"><i class="fa-solid fa-circle-check"></i></div>
                        <div><div class="text-muted small">Low Risk</div><div class="h4 fw-bold mb-0">@low</div></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-warning bg-opacity-10">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="fs-1 text-warning"><i class="fa-solid fa-triangle-exclamation"></i></div>
                        <div><div class="text-muted small">Medium Risk</div><div class="h4 fw-bold mb-0">@medium</div></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-danger bg-opacity-10">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="fs-1 text-danger"><i class="fa-solid fa-skull-crossbones"></i></div>
                        <div><div class="text-muted small">High Risk</div><div class="h4 fw-bold mb-0">@high</div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Fraud #</th>
                                <th>Claim</th>
                                <th>Score</th>
                                <th>Risk</th>
                                <th>Date</th>
                                <th>Notes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model)
                            {
                                var riskBadge = f.RiskFlag switch { "HIGH" => "danger", "MEDIUM" => "warning text-dark", _ => "success" };
                                var scoreWidth = f.FraudScore;
                                var scoreColor = f.FraudScore > 60 ? "danger" : f.FraudScore > 30 ? "warning" : "success";
                                <tr>
                                    <td class="fw-bold">#@f.FraudId</td>
                                    <td><a href="/Claim/GetClaimDetails/@f.ClaimId">#CLM-@f.ClaimId.ToString("D5")</a></td>
                                    <td style="min-width:120px">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:8px">
                                                <div class="progress-bar bg-@scoreColor" style="width:@scoreWidth%"></div>
                                            </div>
                                            <span class="small fw-bold">@f.FraudScore</span>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-@riskBadge">@f.RiskFlag</span></td>
                                    <td class="text-muted small">@f.CheckDate.ToString("MMM dd, yyyy")</td>
                                    <td class="small text-muted" style="max-width:250px">
                                        <span title="@f.Notes" class="text-truncate d-inline-block" style="max-width:200px">@f.Notes</span>
                                    </td>
                                    <td>
                                        <a href="/Fraud/GetFraudScore/@f.ClaimId" class="btn btn-sm btn-outline-primary">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
