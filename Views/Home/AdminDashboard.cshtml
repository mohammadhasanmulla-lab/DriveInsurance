@model MyProject.Models.AdminDashboardViewModel
@{
    ViewBag.Title = "Admin Dashboard - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var claims = ViewBag.AllClaims as List<MyProject.Models.ClaimEntity> ?? new();
    var adminName = Context.Session.GetString("UserName") ?? "Admin";
}

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-0">Admin Dashboard</h4>
            <div class="text-muted small">Hello, @adminName — here's what's happening today</div>
        </div>
        <div class="d-flex gap-2">
            <a href="/Claim/Index" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-file-shield me-1"></i>All Claims</a>
            <a href="/Home/ManageUsers" class="btn btn-primary btn-sm"><i class="fa-solid fa-users-gear me-1"></i>Manage Users</a>
        </div>
    </div>

    <!-- KPI Row -->
    <div class="row g-3 mb-4">
        @{
            var kpis = new[] {
                ("Total Users",        Model.TotalUsers.ToString(),             "fa-users",           "primary",  "/Home/ManageUsers"),
                ("Claims Officers",    Model.ClaimsOfficersCount.ToString(),    "fa-briefcase",       "info",     "/Home/ClaimsOfficers"),
                ("Surveyors",          Model.SurveyOfficersCount.ToString(),    "fa-magnifying-glass","warning",  "/Home/SurveyOfficers"),
                ("Compliance Officers",Model.ComplianceOfficersCount.ToString(),"fa-clipboard-check", "success",  "/Home/ComplianceOfficers"),
                ("Customers",          Model.CustomersCount.ToString(),         "fa-user",            "secondary","/Home/ManageUsers"),
                ("Total Claims",       claims.Count.ToString(),                 "fa-file-shield",     "purple",   "/Claim/Index"),
            };
        }
        @foreach (var (label, val, icon, color, link) in kpis)
        {
            var textColor = color == "purple" ? "style=\"color:#7c3aed\"" : $"class=\"text-{color}\"";
            <div class="col-6 col-md-4 col-xl-2">
                <a href="@link" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <div class="card-body py-3 px-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div class="small text-muted fw-medium">@label</div>
                                <i class="fa-solid @icon @(color == "purple" ? "" : "text-" + color) opacity-50 @(color=="purple"?"" : "")" @(color=="purple" ? "style=\"color:#7c3aed;opacity:.5\"" : "")></i>
                            </div>
                            <div class="h3 fw-bold mb-0 @(color == "purple" ? "" : "text-" + color)" @(color=="purple" ? "style=\"color:#7c3aed\"" : "")>@val</div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <!-- Claims status breakdown -->
    @if (claims.Any())
    {
        <div class="row g-3 mb-4">
            @{
                var cReg = claims.Count(c => c.ClaimStatus == "REGISTERED");
                var cRev = claims.Count(c => c.ClaimStatus == "UNDER_REVIEW");
                var cApp = claims.Count(c => c.ClaimStatus == "APPROVED");
                var cRej = claims.Count(c => c.ClaimStatus == "REJECTED");
                var total = claims.Count;
            }
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                        <span class="fw-semibold"><i class="fa-solid fa-chart-bar me-2 text-primary"></i>Claims Overview</span>
                        <a href="/Claim/Index" class="btn btn-sm btn-outline-primary">View All</a>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @{
                                var statuses = new[] {
                                    ("Registered",   cReg, "secondary"),
                                    ("Under Review", cRev, "warning"),
                                    ("Approved",     cApp, "success"),
                                    ("Rejected",     cRej, "danger"),
                                };
                            }
                            @foreach (var (lbl, cnt, clr) in statuses)
                            {
                                var pct = total > 0 ? (cnt * 100 / total) : 0;
                                <div class="col-6 col-md-3">
                                    <div class="text-muted small mb-1">@lbl</div>
                                    <div class="h4 fw-bold text-@clr mb-1">@cnt</div>
                                    <div class="progress" style="height:6px">
                                        <div class="progress-bar bg-@clr" style="width:@pct%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Users & Officers -->
    <div class="row g-4">
        <!-- All Users table -->
        <div class="col-xl-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                    <span class="fw-semibold"><i class="fa-solid fa-users me-2 text-primary"></i>All Users (@Model.TotalUsers)</span>
                    <a href="/Home/ManageUsers" class="btn btn-sm btn-outline-primary">Manage</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var u in Model.AllUsers.Take(8))
                                {
                                    var roleBadge = u.Role switch {
                                        "Admin"             => "dark",
                                        "ClaimsOfficer"     => "info",
                                        "Surveyor"          => "warning text-dark",
                                        "ComplianceOfficer" => "success",
                                        _                   => "secondary"
                                    };
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold" style="width:34px;height:34px;font-size:.8rem">
                                                    @(string.IsNullOrEmpty(u.FullName) ? u.Username[0..1].ToUpper() : u.FullName[0..1].ToUpper())
                                                </div>
                                                <div>
                                                    <div class="fw-semibold" style="font-size:.875rem">@(u.FullName ?? u.Username)</div>
                                                    <div class="text-muted" style="font-size:.75rem">@@@u.Username</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-muted small">@u.Email</td>
                                        <td><span class="badge bg-@roleBadge">@u.Role.Replace("Officer"," Officer")</span></td>
                                        <td><span class="badge bg-@(u.IsActive ? "success" : "secondary") bg-opacity-10 text-@(u.IsActive ? "success" : "secondary")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                                        <td class="text-muted small">@u.CreatedDate.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick actions -->
        <div class="col-xl-4">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white py-3">
                    <span class="fw-semibold"><i class="fa-solid fa-bolt me-2 text-warning"></i>Quick Actions</span>
                </div>
                <div class="card-body d-grid gap-2">
                    <a href="/Home/ManageUsers"    class="btn btn-outline-primary btn-sm text-start"><i class="fa-solid fa-users-gear me-2"></i>Manage Users</a>
                    <a href="/Claim/Index"          class="btn btn-outline-info btn-sm text-start"><i class="fa-solid fa-file-shield me-2"></i>View All Claims</a>
                    <a href="/Fraud/Index"          class="btn btn-outline-warning btn-sm text-start"><i class="fa-solid fa-shield-halved me-2"></i>Fraud Reports</a>
                    <a href="/Settlement/Index"     class="btn btn-outline-success btn-sm text-start"><i class="fa-solid fa-hand-holding-dollar me-2"></i>Settlements</a>
                    <a href="/Home/ManagePolicies"  class="btn btn-outline-secondary btn-sm text-start"><i class="fa-solid fa-file-contract me-2"></i>Manage Policies</a>
                    <a href="/Home/Logout"          class="btn btn-outline-danger btn-sm text-start"><i class="fa-solid fa-right-from-bracket me-2"></i>Logout</a>
                </div>
            </div>

            <!-- Recent claims mini-list -->
            @if (claims.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-2">
                        <span class="fw-semibold small"><i class="fa-solid fa-clock-rotate-left me-1 text-muted"></i>Recent Claims</span>
                    </div>
                    <div class="card-body py-2 px-3">
                        @foreach (var c in claims.Take(5))
                        {
                            var cb = c.ClaimStatus switch { "APPROVED"=>"success","REJECTED"=>"danger","UNDER_REVIEW"=>"warning text-dark",_=>"secondary" };
                            <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                <div>
                                    <a href="/Claim/GetClaimDetails/@c.ClaimId" class="fw-semibold text-primary text-decoration-none small">#CLM-@c.ClaimId.ToString("D5")</a>
                                    <div class="text-muted" style="font-size:.75rem">@c.ClaimType &bull; @c.ClaimAmount.ToString("C0")</div>
                                </div>
                                <span class="badge bg-@cb" style="font-size:.65rem">@c.ClaimStatus.Replace("_"," ")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
.hover-lift { transition: transform .15s, box-shadow .15s; }
.hover-lift:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.08) !important; }
</style>
