@model List<ClaimsOfficer>
@{
	ViewBag.Title = "Claims Officers - DriveSure Admin";
}

<div class="container-fluid py-4">
	<div class="row mb-4">
		<div class="col-12">
			<div class="d-flex justify-content-between align-items-center">
				<div>
					<h2 class="fw-bold">Claims Officers</h2>
					<p class="text-muted">Manage and view all claims officers</p>
				</div>
				<a href="/Home/AdminDashboard" class="btn btn-outline-primary">
					<i class="fa-solid fa-arrow-left me-2"></i>Back to Dashboard
				</a>
			</div>
		</div>
	</div>

	<div class="row">
		<div class="col-12">
			<div class="card shadow-sm border-0">
				<div class="card-header bg-light border-0">
					<h5 class="mb-0">Total Claims Officers: <span class="badge bg-primary">@Model.Count</span></h5>
				</div>
				<div class="card-body">
					@if (Model.Count == 0)
					{
						<div class="alert alert-info">No claims officers found.</div>
					}
					else
					{
						<div class="table-responsive">
							<table class="table table-hover">
								<thead class="table-light">
									<tr>
										<th>ID</th>
										<th>Name</th>
										<th>Email</th>
										<th>Department</th>
										<th>Claims Handled</th>
										<th>Approval Rate</th>
										<th>Joined Date</th>
										<th>Status</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var officer in Model)
									{
										<tr>
											<td>@officer.Id</td>
											<td>
												<strong>@officer.Username</strong>
											</td>
											<td>@officer.Email</td>
											<td>@officer.Department</td>
											<td>
												<span class="badge bg-light text-dark">@officer.ClaimsHandled</span>
											</td>
											<td>
												<div class="d-flex align-items-center">
													<div class="progress me-2" style="width: 60px; height: 20px;">
														<div class="progress-bar bg-success" style="width: @officer.ApprovalRate%"></div>
													</div>
													<span>@officer.ApprovalRate%</span>
												</div>
											</td>
											<td>@officer.CreatedDate.ToString("MMM dd, yyyy")</td>
											<td>
												@if (officer.IsActive)
												{
													<span class="badge bg-success">Active</span>
												}
												else
												{
													<span class="badge bg-secondary">Inactive</span>
												}
											</td>
											<td>
												<button class="btn btn-sm btn-outline-primary" title="View Details">
													<i class="fa-solid fa-eye"></i>
												</button>
												<button class="btn btn-sm btn-outline-secondary" title="Edit">
													<i class="fa-solid fa-pen"></i>
												</button>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</div>
		</div>
	</div>
</div>
