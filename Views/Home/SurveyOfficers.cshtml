@model List<MyProject.Models.AppUser>
@{
    ViewBag.Title = "Survey Officers - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <a href="/Home/AdminDashboard" class="text-decoration-none text-muted small"><i class="fa-solid fa-arrow-left me-1"></i>Dashboard</a>
        <h4 class="fw-bold mt-1"><i class="fa-solid fa-magnifying-glass me-2 text-warning"></i>Survey Officers</h4>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0"><div class="card-body text-center py-5 text-muted"><i class="fa-solid fa-magnifying-glass fa-3x mb-3 d-block"></i>No surveyors registered yet.</div></div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var u in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="rounded-circle bg-warning bg-opacity-10 text-warning d-flex align-items-center justify-content-center fw-bold" style="width:48px;height:48px;font-size:1.1rem">
                                    @(u.FullName.Length > 0 ? u.FullName[0..1].ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-semibold">@u.FullName</div>
                                    <div class="text-muted small">@@@u.Username</div>
                                </div>
                                <span class="badge bg-@(u.Status=="Active"?"success":"secondary") ms-auto">@u.Status</span>
                            </div>
                            <div class="small text-muted"><i class="fa-solid fa-envelope me-1"></i>@u.Email</div>
                            <div class="small text-muted mt-1"><i class="fa-solid fa-building me-1"></i>@u.Department</div>
                            <div class="small text-muted mt-1"><i class="fa-solid fa-calendar me-1"></i>Joined @u.CreatedDate.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
