@model List<MyProject.Models.AppUser>
@{
    ViewBag.Title = "Manage Users - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <a href="/Home/AdminDashboard" class="text-decoration-none text-muted small"><i class="fa-solid fa-arrow-left me-1"></i>Dashboard</a>
            <h4 class="fw-bold mt-1"><i class="fa-solid fa-users-gear me-2 text-primary"></i>Manage Users</h4>
        </div>
        <a href="/Home/Register" class="btn btn-primary btn-sm"><i class="fa-solid fa-user-plus me-1"></i>Add User</a>
    </div>

    @if (TempData["Success"] != null)
    { <div class="alert alert-success alert-dismissible fade show" style="border-radius:10px;border:none"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

    <!-- Filter tabs -->
    <ul class="nav nav-pills mb-3 gap-1" id="userTabs">
        <li class="nav-item"><button class="nav-link active" data-filter="all">All (@Model.Count)</button></li>
        @foreach (var role in new[]{"Customer","ClaimsOfficer","Surveyor","ComplianceOfficer","Admin"})
        {
            var cnt = Model.Count(u => u.Role == role);
            if (cnt > 0) {
                <li class="nav-item"><button class="nav-link" data-filter="@role">@role.Replace("Officer"," Officer") (@cnt)</button></li>
            }
        }
    </ul>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted"><i class="fa-solid fa-users fa-3x mb-3 d-block"></i>No users registered yet.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="usersTable">
                        <thead class="table-light">
                            <tr><th>User</th><th>Email</th><th>Role</th><th>Department</th><th>Status</th><th>Joined</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                var roleBadge = u.Role switch {
                                    "Admin"             => "dark",
                                    "ClaimsOfficer"     => "info",
                                    "Surveyor"          => "warning text-dark",
                                    "ComplianceOfficer" => "success",
                                    _                   => "secondary"
                                };
                                <tr data-role="@u.Role">
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width:38px;height:38px;font-size:.85rem">
                                                @(u.FullName.Length > 0 ? u.FullName[0..1].ToUpper() : "?")
                                            </div>
                                            <div>
                                                <div class="fw-semibold" style="font-size:.875rem">@u.FullName</div>
                                                <div class="text-muted" style="font-size:.75rem">@@@u.Username</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-muted small">@u.Email</td>
                                    <td><span class="badge bg-@roleBadge">@u.Role.Replace("Officer"," Officer")</span></td>
                                    <td class="text-muted small">@u.Department</td>
                                    <td>
                                        <span class="badge bg-@(u.Status == "Active" ? "success" : "secondary") bg-opacity-10 text-@(u.Status == "Active" ? "success" : "secondary") fw-semibold">
                                            @u.Status
                                        </span>
                                    </td>
                                    <td class="text-muted small">@u.CreatedDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <form asp-action="ToggleUserStatus" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <button type="submit" class="btn btn-sm @(u.Status == "Active" ? "btn-outline-warning" : "btn-outline-success")" title="@(u.Status == "Active" ? "Deactivate" : "Activate")">
                                                <i class="fa-solid @(u.Status == "Active" ? "fa-ban" : "fa-check")"></i>
                                            </button>
                                        </form>
                                        @if (u.Role != "Admin")
                                        {
                                            <button class="btn btn-sm btn-outline-danger ms-1" data-bs-toggle="modal" data-bs-target="#delModal_@u.Id">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>

                                            <!-- Delete confirm modal -->
                                            <div class="modal fade" id="delModal_@u.Id" tabindex="-1">
                                                <div class="modal-dialog modal-sm">
                                                    <div class="modal-content border-0 shadow">
                                                        <div class="modal-header border-0 pb-0">
                                                            <h6 class="modal-title fw-bold">Delete User?</h6>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body pt-1">
                                                            <p class="text-muted small mb-0">This will permanently delete <strong>@u.FullName</strong> and cannot be undone.</p>
                                                        </div>
                                                        <div class="modal-footer border-0 pt-0">
                                                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                                            <form asp-action="DeleteUser" method="post" class="d-inline">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@u.Id" />
                                                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('#userTabs .nav-link').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('#userTabs .nav-link').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const f = this.dataset.filter;
        document.querySelectorAll('#usersTable tbody tr').forEach(row => {
            row.style.display = (f === 'all' || row.dataset.role === f) ? '' : 'none';
        });
    });
});
</script>
}
