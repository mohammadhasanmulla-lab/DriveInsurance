@{
    ViewBag.Title = "DriveSure Insurance — Claims Processing Platform";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        body { background: #fff; color: #0f172a; overflow-x: hidden; }

        /* ── Navbar ── */
        .site-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 999;
            background: rgba(255,255,255,0.92); backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,.07); height: 64px; }
        .nav-logo-icon { width:38px; height:38px; border-radius:10px;
            background: linear-gradient(135deg,#2563eb,#1d4ed8);
            display:flex; align-items:center; justify-content:center; }
        .nav-link-item { font-size:.875rem; font-weight:500; color:#475569;
            text-decoration:none; padding:.35rem .75rem; border-radius:8px;
            transition:background .15s, color .15s; }
        .nav-link-item:hover { background:#eff6ff; color:#2563eb; }

        /* ── Hero ── */
        .hero { min-height: 100vh; display: flex; align-items: center;
            background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 50%, #f5f3ff 100%);
            padding-top: 64px; position: relative; overflow: hidden; }
        .hero::before { content:''; position:absolute; top:-120px; right:-120px;
            width:600px; height:600px; border-radius:50%;
            background: radial-gradient(circle, rgba(37,99,235,.08) 0%, transparent 70%); }
        .hero::after  { content:''; position:absolute; bottom:-80px; left:-80px;
            width:400px; height:400px; border-radius:50%;
            background: radial-gradient(circle, rgba(124,58,237,.06) 0%, transparent 70%); }
        .hero-badge { display:inline-flex; align-items:center; gap:.5rem;
            background:rgba(37,99,235,.08); border:1px solid rgba(37,99,235,.15);
            color:#2563eb; border-radius:20px; padding:.35rem 1rem;
            font-size:.8rem; font-weight:600; margin-bottom:1.5rem; }
        .hero h1 { font-size:clamp(2.2rem,5vw,3.6rem); font-weight:800;
            line-height:1.1; letter-spacing:-.03em; }
        .hero h1 span { background:linear-gradient(135deg,#2563eb,#7c3aed);
            -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
        .btn-hero-primary { background:linear-gradient(135deg,#2563eb,#1d4ed8);
            border:none; border-radius:12px; padding:.85rem 2rem; font-weight:600;
            font-size:.95rem; color:white; transition:transform .15s,box-shadow .2s; }
        .btn-hero-primary:hover { transform:translateY(-2px); box-shadow:0 12px 30px rgba(37,99,235,.35); color:white; }
        .btn-hero-outline { background:white; border:1.5px solid #e2e8f0;
            border-radius:12px; padding:.85rem 2rem; font-weight:600;
            font-size:.95rem; color:#475569; transition:border-color .15s,transform .15s; }
        .btn-hero-outline:hover { border-color:#2563eb; color:#2563eb; transform:translateY(-2px); }

        /* ── Stats strip ── */
        .stats-strip { background:white; border-top:1px solid #f1f5f9;
            border-bottom:1px solid #f1f5f9; }
        .stat-item { text-align:center; padding:2rem 1rem; }
        .stat-num { font-size:2.2rem; font-weight:800; background:linear-gradient(135deg,#2563eb,#7c3aed);
            -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }

        /* ── Features ── */
        .section-label { font-size:.75rem; font-weight:700; letter-spacing:.1em;
            text-transform:uppercase; color:#2563eb; margin-bottom:.75rem; }
        .feature-card { border:1.5px solid #f1f5f9; border-radius:16px; padding:2rem;
            height:100%; transition:border-color .2s, box-shadow .2s, transform .2s; }
        .feature-card:hover { border-color:#c7d2fe; box-shadow:0 8px 32px rgba(37,99,235,.08); transform:translateY(-3px); }
        .feature-icon { width:52px; height:52px; border-radius:14px; display:flex;
            align-items:center; justify-content:center; font-size:1.3rem; margin-bottom:1.25rem; }

        /* ── Process timeline ── */
        .process-step { display:flex; flex-direction:column; align-items:center; text-align:center; position:relative; flex:1; }
        .process-dot { width:56px; height:56px; border-radius:50%; display:flex;
            align-items:center; justify-content:center; font-size:1.1rem;
            border:2px solid #e2e8f0; background:white; position:relative; z-index:1; }
        .process-line { position:absolute; top:28px; left:calc(50% + 28px); right:calc(-50% + 28px);
            height:2px; background:linear-gradient(90deg,#2563eb,#7c3aed); z-index:0; }

        /* ── Roles ── */
        .role-card { border-radius:16px; padding:2rem; border:1.5px solid #f1f5f9;
            transition:border-color .2s,transform .2s,box-shadow .2s; }
        .role-card:hover { transform:translateY(-4px); box-shadow:0 12px 32px rgba(0,0,0,.07); }

        /* ── CTA ── */
        .cta-section { background:linear-gradient(135deg,#1e3a8a 0%,#1d4ed8 50%,#7c3aed 100%);
            border-radius:24px; padding:4rem 2rem; text-align:center; }

        /* ── Footer ── */
        .site-footer { background:#0f172a; color:#94a3b8; }
    </style>
</head>
<body>

<!-- ── Navbar ─────────────────────────────────────────────────────────────── -->
<nav class="site-nav d-flex align-items-center px-4">
    <a href="/" class="d-flex align-items-center gap-2 text-decoration-none me-auto">
        <div class="nav-logo-icon"><i class="fa-solid fa-shield-halved text-white fa-sm"></i></div>
        <div>
            <div class="fw-bold text-dark" style="font-size:.95rem;line-height:1.1">DriveSure</div>
            <div class="text-muted" style="font-size:.65rem">Insurance Platform</div>
        </div>
    </a>
    <div class="d-none d-md-flex align-items-center gap-1 me-4">
        <a href="#features" class="nav-link-item">Features</a>
        <a href="#how-it-works" class="nav-link-item">How It Works</a>
        <a href="#roles" class="nav-link-item">Roles</a>
        <a href="#contact" class="nav-link-item">Contact</a>
    </div>
    <div class="d-flex gap-2">
        <a href="/Home/Login"    class="btn btn-sm btn-outline-primary" style="border-radius:9px;font-weight:600">Sign In</a>
        <a href="/Home/Register" class="btn btn-sm btn-primary"         style="border-radius:9px;font-weight:600">Get Started</a>
    </div>
</nav>

<!-- ── Hero ───────────────────────────────────────────────────────────────── -->
<section class="hero">
    <div class="container" style="position:relative;z-index:1">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="hero-badge">
                    <i class="fa-solid fa-circle-check"></i> Trusted Claims Platform
                </div>
                <h1 class="mb-4">
                    Insurance Claims,<br>
                    <span>Processed Smarter</span>
                </h1>
                <p class="text-muted mb-4" style="font-size:1.1rem;line-height:1.7;max-width:480px">
                    From registration to settlement — DriveSure automates every step of the claims pipeline with built-in fraud detection and compliance checks.
                </p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <a href="/Home/Register" class="btn-hero-primary text-decoration-none">
                        <i class="fa-solid fa-rocket me-2"></i>Start Free
                    </a>
                    <a href="#how-it-works" class="btn-hero-outline text-decoration-none">
                        <i class="fa-solid fa-play-circle me-2"></i>See How It Works
                    </a>
                </div>
                <div class="d-flex flex-wrap gap-3 mt-2">
                    @foreach (var tag in new[]{"No credit card","BCrypt encrypted","Role-based access","Local deployment"})
                    {
                        <div class="d-flex align-items-center gap-1 text-muted" style="font-size:.82rem">
                            <i class="fa-solid fa-check text-success fa-xs"></i> @tag
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <!-- Decorative dashboard mockup card -->
                <div style="background:white;border-radius:20px;padding:1.5rem;box-shadow:0 24px 64px rgba(37,99,235,.12);border:1px solid #e2e8f0">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div style="width:10px;height:10px;border-radius:50%;background:#ef4444"></div>
                        <div style="width:10px;height:10px;border-radius:50%;background:#f59e0b"></div>
                        <div style="width:10px;height:10px;border-radius:50%;background:#22c55e"></div>
                        <div class="ms-2 text-muted" style="font-size:.75rem">Claims Dashboard</div>
                    </div>
                    <div class="row g-2 mb-3">
                        @foreach (var (lbl,val,clr) in new[]{("Total Claims","124","primary"),("Approved","89","success"),("Pending","28","warning"),("Rejected","7","danger")})
                        {
                            <div class="col-6">
                                <div style="background:#f8fafc;border-radius:12px;padding:.85rem">
                                    <div class="text-muted" style="font-size:.72rem">@lbl</div>
                                    <div class="fw-bold text-@clr" style="font-size:1.5rem">@val</div>
                                </div>
                            </div>
                        }
                    </div>
                    <div style="background:#f8fafc;border-radius:12px;padding:1rem">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span style="font-size:.8rem;font-weight:600">Recent Claims</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:.7rem">Live</span>
                        </div>
                        @foreach (var (id,type,status,clr) in new[]{
                            ("#CLM-00124","Collision","Under Review","warning"),
                            ("#CLM-00123","Fire Damage","Approved","success"),
                            ("#CLM-00122","Theft","Registered","secondary")})
                        {
                            <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                <div>
                                    <div class="fw-semibold text-primary" style="font-size:.8rem">@id</div>
                                    <div class="text-muted" style="font-size:.72rem">@type</div>
                                </div>
                                <span class="badge bg-@clr bg-opacity-10 text-@clr" style="font-size:.68rem">@status</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Stats strip ─────────────────────────────────────────────────────────── -->
<div class="stats-strip">
    <div class="container">
        <div class="row g-0 divide-x">
            @foreach (var (num,lbl) in new[]{("5+","Claim Modules"),("BCrypt","Password Security"),("Role-Based","Access Control"),("Real-time","Fraud Scoring"),("EF Core","ORM & Migrations")})
            {
                <div class="col-6 col-md stat-item">
                    <div class="stat-num">@num</div>
                    <div class="text-muted small fw-medium">@lbl</div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ── Features ───────────────────────────────────────────────────────────── -->
<section id="features" class="py-6" style="padding:5rem 0">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Platform Features</div>
            <h2 class="fw-bold" style="font-size:2.2rem">Everything you need to manage claims</h2>
            <p class="text-muted mx-auto mt-2" style="max-width:540px;font-size:.975rem">
                A complete MVC-based pipeline covering every stage of the insurance claim lifecycle.
            </p>
        </div>
        <div class="row g-4">
            @{
                var features = new[] {
                    ("fa-file-circle-plus","#dbeafe","#2563eb","Claim Registration","Submit and validate claims against active policies with real-time coverage checks."),
                    ("fa-paperclip","#dcfce7","#16a34a","Document Submission","Upload supporting documents with simulated OCR-based verification and status tracking."),
                    ("fa-magnifying-glass-chart","#fef9c3","#ca8a04","Surveyor Assessment","Assign surveyors from the database, record damage assessments and findings."),
                    ("fa-shield-halved","#fce7f3","#9d174d","Fraud Detection","Rule-based scoring engine flags claims as LOW / MEDIUM / HIGH risk automatically."),
                    ("fa-hand-holding-dollar","#f0fdf4","#15803d","Settlement & Payment","Approve, reject or process simulated payment with generated payment references."),
                    ("fa-users-gear","#f5f3ff","#7c3aed","User Management","Admin creates and manages users across all roles with live DB-backed authentication."),
                };
            }
            @foreach (var (icon, bg, clr, title, desc) in features)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon" style="background:@bg">
                            <i class="fa-solid @icon" style="color:@clr"></i>
                        </div>
                        <h5 class="fw-bold mb-2">@title</h5>
                        <p class="text-muted mb-0" style="font-size:.875rem;line-height:1.6">@desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── How It Works ────────────────────────────────────────────────────────── -->
<section id="how-it-works" style="padding:5rem 0;background:#f8fafc">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">The Process</div>
            <h2 class="fw-bold" style="font-size:2.2rem">How a claim flows through the system</h2>
        </div>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-4">
            @{
                var steps = new[] {
                    ("fa-file-plus","#dbeafe","#2563eb","Register","Customer submits a claim with policy and incident details."),
                    ("fa-paperclip","#dcfce7","#16a34a","Upload Docs","Supporting documents uploaded and verified via OCR simulation."),
                    ("fa-user-tie","#fef9c3","#ca8a04","Survey","A surveyor is assigned and records the assessed damage amount."),
                    ("fa-shield-halved","#fce7f3","#9d174d","Fraud Check","Automated rule engine scores the claim for risk level."),
                    ("fa-circle-check","#f0fdf4","#15803d","Settle","Officer approves settlement and payment is processed."),
                };
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var (icon, bg, clr, lbl, desc) = steps[i];
                <div class="process-step flex-fill">
                    <div class="process-dot mb-3" style="background:@bg;border-color:@clr">
                        <i class="fa-solid @icon" style="color:@clr;font-size:1.1rem"></i>
                    </div>
                    @if (i < steps.Length - 1)
                    {
                        <div class="process-line d-none d-md-block"></div>
                    }
                    <div class="fw-bold" style="font-size:.9rem">@lbl</div>
                    <div class="text-muted mt-1 px-2" style="font-size:.78rem;line-height:1.5">@desc</div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── Roles ───────────────────────────────────────────────────────────────── -->
<section id="roles" style="padding:5rem 0">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Access Control</div>
            <h2 class="fw-bold" style="font-size:2.2rem">Built for every role in the team</h2>
            <p class="text-muted mt-2" style="font-size:.975rem">Each role gets a tailored dashboard and permissions.</p>
        </div>
        <div class="row g-4">
            @{
                var roles = new[] {
                    ("fa-user","linear-gradient(135deg,#dbeafe,#bfdbfe)","#1d4ed8","Customer",
                     new[]{"Register new claims","Upload documents","Track claim status","View settlement details"}),
                    ("fa-briefcase","linear-gradient(135deg,#dcfce7,#bbf7d0)","#15803d","Claims Officer",
                     new[]{"Review all claims","Assign surveyors","Run fraud checks","Approve / reject settlements"}),
                    ("fa-magnifying-glass","linear-gradient(135deg,#fef9c3,#fde68a)","#a16207","Surveyor",
                     new[]{"View assigned assessments","Record damage amounts","Add assessment remarks","Update assessment status"}),
                    ("fa-clipboard-check","linear-gradient(135deg,#fce7f3,#fbcfe8)","#9d174d","Compliance Officer",
                     new[]{"Review fraud scores","Run compliance checks","Monitor high-risk claims","View full fraud report"}),
                    ("fa-crown","linear-gradient(135deg,#f5f3ff,#ede9fe)","#6d28d9","Admin",
                     new[]{"Manage all users","View full dashboard","Configure policies","Access all modules"}),
                };
            }
            @foreach (var (icon, bg, clr, role, perms) in roles)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="role-card">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div style="width:48px;height:48px;border-radius:14px;background:@bg;display:flex;align-items:center;justify-content:center">
                                <i class="fa-solid @icon" style="color:@clr;font-size:1.2rem"></i>
                            </div>
                            <div class="fw-bold fs-5">@role</div>
                        </div>
                        <ul class="list-unstyled mb-0">
                            @foreach (var p in perms)
                            {
                                <li class="d-flex align-items-center gap-2 mb-1" style="font-size:.85rem;color:#475569">
                                    <i class="fa-solid fa-check-circle" style="color:@clr;font-size:.75rem"></i> @p
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── CTA ─────────────────────────────────────────────────────────────────── -->
<section style="padding:5rem 0;background:#f8fafc">
    <div class="container">
        <div class="cta-section">
            <div class="d-inline-flex align-items-center gap-2 mb-3" style="background:rgba(255,255,255,.12);border-radius:20px;padding:.4rem 1rem">
                <i class="fa-solid fa-shield-halved text-white fa-sm"></i>
                <span class="text-white" style="font-size:.8rem;font-weight:600">Secure & Ready to Deploy</span>
            </div>
            <h2 class="text-white fw-bold mb-3" style="font-size:2.4rem">Ready to process your first claim?</h2>
            <p class="mb-4" style="color:rgba(255,255,255,.75);font-size:1rem;max-width:480px;margin:0 auto 1.5rem">
                Create an account in seconds. No setup fees, no credit card — just register and start managing claims immediately.
            </p>
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a href="/Home/Register" class="btn btn-light fw-bold px-4 py-2" style="border-radius:12px">
                    <i class="fa-solid fa-user-plus me-2 text-primary"></i>Create Account
                </a>
                <a href="/Home/Login" class="btn fw-bold px-4 py-2 text-white" style="border-radius:12px;border:1.5px solid rgba(255,255,255,.4)">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>Sign In
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ── Contact ─────────────────────────────────────────────────────────────── -->
<section id="contact" style="padding:4rem 0">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="section-label">Contact Us</div>
                <h2 class="fw-bold mb-3" style="font-size:2rem">Have questions?</h2>
                <p class="text-muted mb-4">Our support team is available to help you get set up and running.</p>
                <div class="row g-4 justify-content-center">
                    @foreach (var (icon,clr,label,val) in new[]{
                        ("fa-envelope","#2563eb","Email","support@drivesure.com"),
                        ("fa-phone","#16a34a","Phone","+1 (800) 555-0100"),
                        ("fa-clock","#ca8a04","Hours","Mon–Fri, 9am–6pm")})
                    {
                        <div class="col-sm-4">
                            <div class="d-flex flex-column align-items-center gap-2">
                                <div style="width:48px;height:48px;border-radius:14px;background:#f8fafc;border:1.5px solid #e2e8f0;display:flex;align-items:center;justify-content:center">
                                    <i class="fa-solid @icon" style="color:@clr"></i>
                                </div>
                                <div class="text-muted small fw-medium">@label</div>
                                <div class="fw-semibold" style="font-size:.9rem">@val</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Footer ─────────────────────────────────────────────────────────────── -->
<footer class="site-footer py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="nav-logo-icon"><i class="fa-solid fa-shield-halved text-white fa-sm"></i></div>
                    <span class="text-white fw-bold">DriveSure Insurance</span>
                </div>
                <p style="color:#64748b;font-size:.875rem;line-height:1.6">
                    A full-featured insurance claims processing platform built on ASP.NET Core MVC with Entity Framework Core and role-based access control.
                </p>
            </div>
            <div class="col-6 col-lg-2 offset-lg-2">
                <div class="fw-semibold text-white mb-3 small">Platform</div>
                <ul class="list-unstyled" style="font-size:.875rem">
                    @foreach (var (lbl,href) in new[]{("Features","#features"),("How It Works","#how-it-works"),("Roles","#roles"),("Sign In","/Home/Login"),("Register","/Home/Register")})
                    { <li class="mb-2"><a href="@href" style="color:#64748b;text-decoration:none" class="hover-link">@lbl</a></li> }
                </ul>
            </div>
            <div class="col-6 col-lg-2">
                <div class="fw-semibold text-white mb-3 small">Modules</div>
                <ul class="list-unstyled" style="font-size:.875rem">
                    @foreach (var lbl in new[]{"Claim Registration","Document Upload","Assessment","Fraud Detection","Settlement"})
                    { <li class="mb-2" style="color:#64748b">@lbl</li> }
                </ul>
            </div>
            <div class="col-6 col-lg-2">
                <div class="fw-semibold text-white mb-3 small">Tech Stack</div>
                <ul class="list-unstyled" style="font-size:.875rem">
                    @foreach (var lbl in new[]{"ASP.NET Core 10","Entity Framework Core","SQL Server","BCrypt.Net","Bootstrap 5"})
                    { <li class="mb-2" style="color:#64748b">@lbl</li> }
                </ul>
            </div>
        </div>
        <hr style="border-color:#1e293b;margin:2rem 0" />
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div style="color:#475569;font-size:.8rem">&copy; @DateTime.Now.Year DriveSure Insurance. All rights reserved.</div>
            <div class="d-flex gap-3">
                @foreach (var (icon,lbl) in new[]{("fa-lock","Privacy"),("fa-file-lines","Terms"),("fa-circle-question","Support")})
                { <a href="#" style="color:#475569;text-decoration:none;font-size:.8rem"><i class="fa-solid @icon me-1"></i>@lbl</a> }
            </div>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
            const t = document.querySelector(a.getAttribute('href'));
            if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
        });
    });
    // Navbar shadow on scroll
    window.addEventListener('scroll', () => {
        document.querySelector('.site-nav').style.boxShadow =
            window.scrollY > 10 ? '0 2px 16px rgba(0,0,0,.08)' : 'none';
    });
</script>
</body>
</html>
