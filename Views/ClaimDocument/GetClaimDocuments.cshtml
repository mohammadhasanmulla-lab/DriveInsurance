@model List<MyProject.Models.ClaimDocumentEntity>
@{
    ViewBag.Title = "Claim Documents - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int claimId = ViewBag.ClaimId;
    var role = Context.Session.GetString("UserRole") ?? "";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <a href="/Claim/GetClaimDetails/@claimId" class="text-decoration-none text-muted small"><i class="fa-solid fa-arrow-left me-1"></i>Back to Claim #CLM-@claimId.ToString("D5")</a>
            <h4 class="fw-bold mt-1"><i class="fa-solid fa-paperclip me-2 text-secondary"></i>Documents</h4>
        </div>
        <a href="/ClaimDocument/UploadClaimDocument/@claimId" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-upload me-1"></i> Upload Document
        </a>
    </div>

    @if (TempData["Success"] != null)
    { <div class="alert alert-success alert-dismissible fade show"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Error"] != null)
    { <div class="alert alert-danger alert-dismissible fade show"><i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

    @if (!Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5 text-muted">
                <i class="fa-solid fa-folder-open fa-3x mb-3 d-block"></i>
                No documents uploaded for this claim.
                <a href="/ClaimDocument/UploadClaimDocument/@claimId" class="d-block mt-2">Upload the first document</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var doc in Model)
            {
                var badgeClass = doc.VerificationStatus switch {
                    "VERIFIED" => "success",
                    "REJECTED" => "danger",
                    _ => "warning text-dark"
                };
                var docExt = doc.DocumentName.Contains('.') ? doc.DocumentName.Substring(doc.DocumentName.LastIndexOf('.')).ToLower() : "";
                var icon = docExt == ".pdf" ? "fa-file-pdf text-danger"
                         : docExt == ".jpg" || docExt == ".jpeg" || docExt == ".png" ? "fa-file-image text-info"
                         : docExt == ".docx" ? "fa-file-word text-primary"
                         : "fa-file text-secondary";
                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-start gap-3">
                                <div class="fs-2"><i class="fa-solid @icon"></i></div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-semibold text-truncate">@doc.DocumentName</div>
                                    <div class="text-muted small">Uploaded @doc.UploadedDate.ToString("MMM dd, yyyy")</div>
                                    <div class="mt-1">
                                        <span class="badge bg-@badgeClass">@doc.VerificationStatus</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(doc.RejectionReason))
                                    { <div class="small text-danger mt-1">@doc.RejectionReason</div> }
                                </div>
                            </div>
                        </div>
                        @if (role is "ClaimsOfficer" or "ComplianceOfficer" or "Admin")
                        {
                            <div class="card-footer bg-white d-flex gap-2">
                                @if (doc.VerificationStatus == "PENDING")
                                {
                                    <form asp-action="ValidateClaimDocument" asp-controller="ClaimDocument" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                        <input type="hidden" name="claimId" value="@claimId" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Verify (OCR)
                                        </button>
                                    </form>
                                    <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rejectModal_@doc.DocumentId">
                                        <i class="fa-solid fa-xmark me-1"></i> Reject
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">No actions available</span>
                                }
                            </div>

                            <!-- Reject modal -->
                            <div class="modal fade" id="rejectModal_@doc.DocumentId" tabindex="-1">
                                <div class="modal-dialog modal-sm">
                                    <div class="modal-content">
                                        <div class="modal-header"><h6 class="modal-title">Reject Document</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                                        <form asp-action="RejectDocument" asp-controller="ClaimDocument" method="post">
                                            @Html.AntiForgeryToken()
                                            <div class="modal-body">
                                                <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                                <input type="hidden" name="claimId" value="@claimId" />
                                                <label class="form-label small">Rejection Reason</label>
                                                <textarea name="reason" class="form-control form-control-sm" rows="2" required></textarea>
                                            </div>
                                            <div class="modal-footer py-2">
                                                <button type="submit" class="btn btn-danger btn-sm">Confirm Reject</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
