@{
    Layout = null;
    var title    = ViewBag.Title ?? "DriveSure Insurance";
    var userRole = Context.Session.GetString("UserRole");
    var userName = Context.Session.GetString("UserName");
    var loggedIn = !string.IsNullOrEmpty(userRole);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8fafc; }
        .topnav {
            background: white; border-bottom: 1px solid #e2e8f0;
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000; height: 60px;
        }
        .topnav .brand-icon { width:36px;height:36px;background:linear-gradient(135deg,#2563eb,#1d4ed8);border-radius:9px; }
        .sidebar {
            position: fixed; top: 60px; left: 0; bottom: 0; width: 230px;
            background: white; border-right: 1px solid #e2e8f0;
            overflow-y: auto; z-index: 900; transition: transform .25s;
        }
        .sidebar .nav-link {
            color: #475569; border-radius: 8px; padding: .5rem .85rem; font-size: .875rem;
            display: flex; align-items: center; gap: .65rem; font-weight: 500;
            transition: background .15s, color .15s;
        }
        .sidebar .nav-link:hover, .sidebar .nav-link.active {
            background: #eff6ff; color: #2563eb;
        }
        .sidebar .nav-link i { width: 18px; text-align: center; font-size: .9rem; }
        .sidebar-section { font-size: .7rem; font-weight: 600; color: #94a3b8; letter-spacing: .06em; text-transform: uppercase; padding: .75rem .85rem .3rem; }
        .main-content { margin-left: 230px; margin-top: 60px; min-height: calc(100vh - 60px); }
        @@media (max-width: 991px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; }
        }
        .user-avatar { width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#2563eb,#7c3aed);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:.8rem; }
        .role-pill { font-size:.65rem;padding:.2rem .5rem;border-radius:20px;font-weight:600; }
    </style>
    @RenderSection("Head", required: false)
</head>
<body>

<!-- Top navbar -->
<nav class="topnav d-flex align-items-center px-3 px-md-4">
    <button class="btn btn-sm btn-outline-secondary me-3 d-lg-none border-0" id="sideToggle">
        <i class="fa-solid fa-bars"></i>
    </button>
    <a class="d-flex align-items-center gap-2 text-decoration-none" href="/">
        <div class="brand-icon d-flex align-items-center justify-content-center">
            <i class="fa-solid fa-shield-halved text-white fa-sm"></i>
        </div>
        <div class="d-none d-sm-block">
            <div class="fw-bold text-dark" style="font-size:.9rem;line-height:1.1">DriveSure</div>
            <div class="text-muted" style="font-size:.68rem">Insurance Claims</div>
        </div>
    </a>

    <div class="ms-auto d-flex align-items-center gap-3">
        @if (loggedIn)
        {
            <div class="d-none d-md-flex align-items-center gap-2">
                <div class="user-avatar">@(userName?.Length > 0 ? userName[0..1].ToUpper() : "U")</div>
                <div>
                    <div class="fw-semibold text-dark" style="font-size:.8rem">@userName</div>
                    <div class="text-muted" style="font-size:.68rem">@userRole?.Replace("Officer"," Officer")</div>
                </div>
            </div>
            <a href="/Home/Logout" class="btn btn-sm btn-outline-danger" style="border-radius:8px;font-size:.8rem">
                <i class="fa-solid fa-right-from-bracket me-1"></i><span class="d-none d-sm-inline">Logout</span>
            </a>
        }
        else
        {
            <a href="/Home/Login" class="btn btn-primary btn-sm" style="border-radius:8px">Sign In</a>
        }
    </div>
</nav>

@if (loggedIn)
{
    <!-- Sidebar -->
    <nav class="sidebar py-3 px-2" id="sidebar">
        <div class="sidebar-section">Main</div>
        <ul class="nav flex-column gap-1 mb-2">
            @{
                string? dash = userRole switch {
                    "Admin"             => "/Home/AdminDashboard",
                    "ClaimsOfficer"     => "/Claim/Index",
                    "Surveyor"          => "/Assessment/Index",
                    "ComplianceOfficer" => "/Fraud/Index",
                    _                   => "/Customer/Dashboard"
                };
            }
            <li class="nav-item">
                <a class="nav-link @(ViewBag.Title?.ToString()?.Contains("Dashboard") == true ? "active" : "")" href="@dash">
                    <i class="fa-solid fa-gauge-high"></i> Dashboard
                </a>
            </li>
        </ul>

        @if (userRole == "Customer")
        {
            <div class="sidebar-section">Claims</div>
            <ul class="nav flex-column gap-1 mb-2">
                <li><a class="nav-link" href="/Claim/RegisterClaim"><i class="fa-solid fa-file-circle-plus"></i> Register Claim</a></li>
                <li><a class="nav-link" href="/Claim/Index"><i class="fa-solid fa-list"></i> My Claims</a></li>
            </ul>
        }

        @if (userRole is "ClaimsOfficer" or "Admin")
        {
            <div class="sidebar-section">Claims</div>
            <ul class="nav flex-column gap-1 mb-2">
                <li><a class="nav-link" href="/Claim/Index"><i class="fa-solid fa-file-shield"></i> All Claims</a></li>
                <li><a class="nav-link" href="/Assessment/Index"><i class="fa-solid fa-magnifying-glass-chart"></i> Assessments</a></li>
                <li><a class="nav-link" href="/Fraud/Index"><i class="fa-solid fa-shield-halved"></i> Fraud Checks</a></li>
                <li><a class="nav-link" href="/Settlement/Index"><i class="fa-solid fa-hand-holding-dollar"></i> Settlements</a></li>
            </ul>
        }

        @if (userRole == "Surveyor")
        {
            <div class="sidebar-section">Work</div>
            <ul class="nav flex-column gap-1 mb-2">
                <li><a class="nav-link" href="/Assessment/Index"><i class="fa-solid fa-magnifying-glass-chart"></i> My Assessments</a></li>
                <li><a class="nav-link" href="/Claim/Index"><i class="fa-solid fa-file-shield"></i> Claims</a></li>
            </ul>
        }

        @if (userRole == "ComplianceOfficer")
        {
            <div class="sidebar-section">Compliance</div>
            <ul class="nav flex-column gap-1 mb-2">
                <li><a class="nav-link" href="/Fraud/Index"><i class="fa-solid fa-shield-halved"></i> Fraud Reports</a></li>
                <li><a class="nav-link" href="/Claim/Index"><i class="fa-solid fa-file-shield"></i> Claims</a></li>
            </ul>
        }

        @if (userRole == "Admin")
        {
            <div class="sidebar-section">Administration</div>
            <ul class="nav flex-column gap-1 mb-2">
                <li><a class="nav-link" href="/Home/ManageUsers"><i class="fa-solid fa-users-gear"></i> Manage Users</a></li>
                <li><a class="nav-link" href="/Home/ManagePolicies"><i class="fa-solid fa-file-contract"></i> Policies</a></li>
            </ul>
        }

        <div class="mt-auto pt-2 border-top mx-2">
            <a class="nav-link text-danger" href="/Home/Logout">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
    </nav>

    <!-- Main content with sidebar -->
    <main class="main-content p-3 p-md-4">
        @RenderBody()
    </main>
}
else
{
    <!-- No sidebar for guests -->
    <main style="margin-top:60px">
        @RenderBody()
    </main>
}

<!-- Footer -->
<footer class="bg-white border-top text-center text-muted py-3" style="font-size:.78rem; @(loggedIn ? "margin-left:230px;" : "") margin-top:0">
    DriveSure Insurance &copy; @DateTime.Now.Year &mdash;
    <a href="#" class="text-muted text-decoration-none me-2">Privacy</a>
    <a href="#" class="text-muted text-decoration-none">Support</a>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // Mobile sidebar toggle
    const toggle = document.getElementById('sideToggle');
    const sidebar = document.getElementById('sidebar');
    if (toggle && sidebar) {
        toggle.addEventListener('click', () => sidebar.classList.toggle('open'));
    }
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
