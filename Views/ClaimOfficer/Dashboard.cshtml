@{
	ViewBag.Title = "Claim Officer - DriveSure";
	ViewBag.Active = "Dashboard";
	ViewBag.UserName = "Officer Sam";
}
<div class="row g-3">
	<div class="col-lg-3 d-none d-lg-block">
		@await Html.PartialAsync("_Sidebar")
	</div>
	<div class="col-lg-9">
		<div class="d-flex justify-content-between align-items-center mb-3">
			<div>
				<h4 class="mb-0">Claim Officer Dashboard</h4>
				<div class="small text-muted">Manage and process incoming claims</div>
			</div>
			<div>
				<button class="btn btn-outline-primary me-2"><i class="fa-solid fa-download me-1"></i> Export</button>
				<button class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i> New Task</button>
			</div>
		</div>

n        <div class="row g-3 mb-3">
			<div class="col-md-4">
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="small text-muted">Total Claims Today</div>
						<div class="h4 fw-bold">24</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="small text-muted">Pending Approval</div>
						<div class="h4 fw-bold">6</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="small text-muted">Assigned Surveyors</div>
						<div class="h4 fw-bold">8</div>
					</div>
				</div>
			</div>
		</div>

n        <div class="card shadow-sm">
			<div class="card-body">
				<h6 class="mb-3">Claims</h6>
				<div class="table-responsive">
					<table class="table table-hover align-middle">
						<thead class="table-light">
							<tr>
								<th>Claim ID</th>
								<th>Customer</th>
								<th>Policy</th>
								<th>Status</th>
								<th class="text-end">Actions</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td>CLM-10321</td>
								<td>John Smith</td>
								<td>Auto - 3421</td>
								<td><span class="badge bg-warning text-dark">Under Review</span></td>
								<td class="text-end">
									<button class="btn btn-sm btn-success me-1"><i class="fa-solid fa-check"></i> Approve</button>
									<button class="btn btn-sm btn-danger"><i class="fa-solid fa-xmark"></i> Reject</button>
								</td>
							</tr>
							<tr>
								<td>CLM-10319</td>
								<td>Mary Evans</td>
								<td>Home - 8812</td>
								<td><span class="badge bg-info text-dark">Survey Assigned</span></td>
								<td class="text-end">
									<button class="btn btn-sm btn-primary me-1"><i class="fa-solid fa-user-plus"></i> Assign</button>
									<button class="btn btn-sm btn-secondary"><i class="fa-solid fa-eye"></i> View</button>
								</td>
							</tr>
							<tr>
								<td>CLM-10305</td>
								<td>Samuel Green</td>
								<td>Auto - 5532</td>
								<td><span class="badge bg-success">Approved</span></td>
								<td class="text-end"><button class="btn btn-sm btn-secondary"><i class="fa-solid fa-eye"></i> View</button></td>
							</tr>
						</tbody>
					</table>
				</div>
			</div>
		</div>

n    </div>
</div>