@{
	ViewBag.Title = "Customer Dashboard - DriveSure";
	ViewBag.Active = "Dashboard";
	ViewBag.UserName = "Jane Doe";
}
<div class="row g-3">
	<div class="col-lg-3 d-none d-lg-block">
		@await Html.PartialAsync("_Sidebar")
	</div>

	<div class="col-lg-9">
		<div class="d-flex align-items-center justify-content-between mb-3">
			<div>
				<h4 class="mb-0">Welcome back, <span class="text-primary">Jane</span></h4>
				<div class="text-muted small">Here's an overview of your account</div>
			</div>
			<div>
				<button class="btn btn-outline-primary me-2"><i class="fa-solid fa-file-circle-plus me-1"></i> Submit Claim</button>
				<button class="btn btn-primary"><i class="fa-solid fa-eye me-1"></i> Track Claim</button>
			</div>
		</div>

n        <div class="row g-3 mb-3">
			<div class="col-md-4">
				<div class="card shadow-sm rounded">
					<div class="card-body">
						<div class="d-flex align-items-center">
							<div class="me-3 display-6 text-primary"><i class="fa-solid fa-id-card"></i></div>
							<div>
								<div class="small text-muted">Active Policies</div>
								<div class="h5 fw-bold">3</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm rounded">
					<div class="card-body">
						<div class="d-flex align-items-center">
							<div class="me-3 display-6 text-warning"><i class="fa-solid fa-clock"></i></div>
							<div>
								<div class="small text-muted">Pending Claims</div>
								<div class="h5 fw-bold">1</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm rounded">
					<div class="card-body">
						<div class="d-flex align-items-center">
							<div class="me-3 display-6 text-success"><i class="fa-solid fa-hand-holding-dollar"></i></div>
							<div>
								<div class="small text-muted">Approved Claims</div>
								<div class="h5 fw-bold">5</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

n        <!-- Claim Progress -->
		<div class="card shadow-sm mb-3">
			<div class="card-body">
				<div class="d-flex justify-content-between">
					<div>
						<h6 class="mb-1">Claim #CLM-10234</h6>
						<div class="small text-muted">Submitted on 2026-06-01</div>
					</div>
					<div class="text-end">
						<div class="small text-muted">Status: <span class="fw-semibold text-warning">Under Review</span></div>
					</div>
				</div>
				<div class="progress progress-sm mt-3" style="height:12px;">
					<div class="progress-bar bg-primary" role="progressbar" style="width: 55%" aria-valuenow="55" aria-valuemin="0" aria-valuemax="100">55%</div>
				</div>
				<div class="d-flex justify-content-between small text-muted mt-2">
					<div>Submit</div><div>Review</div><div>Survey</div><div>Compliance</div><div>Approval</div>
				</div>
			</div>
		</div>

n        <!-- Recent activity / quick actions -->
		<div class="row g-3">
			<div class="col-md-6">
				<div class="card shadow-sm">
					<div class="card-body">
						<h6>Recent Claims</h6>
						<ul class="list-unstyled mb-0">
							<li class="py-2 border-bottom d-flex justify-content-between">
								<div>
									<div class="fw-semibold">#CLM-10234</div>
									<div class="small text-muted">Collision - Vehicle</div>
								</div>
								<div class="text-end">
									<div class="small text-muted">Under Review</div>
								</div>
							</li>
							<li class="py-2 border-bottom d-flex justify-content-between">
								<div>
									<div class="fw-semibold">#CLM-10120</div>
									<div class="small text-muted">Glass - Windshield</div>
								</div>
								<div class="text-end">
									<div class="small text-muted">Approved</div>
								</div>
							</li>
						</ul>
					</div>
				</div>
			</div>

n            <div class="col-md-6">
				<div class="card shadow-sm">
					<div class="card-body">
						<h6>Quick Actions</h6>
						<div class="d-grid gap-2">
							<button class="btn btn-outline-primary">Start New Claim</button>
							<button class="btn btn-outline-secondary">Download Policy</button>
							<button class="btn btn-outline-success">Contact Support</button>
						</div>
					</div>
				</div>
			</div>
		</div>

n    </div>
</div>