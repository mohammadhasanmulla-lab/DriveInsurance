@{
	ViewBag.Title = "Admin Dashboard - DriveSure";
	ViewBag.Active = "Dashboard";
	ViewBag.UserName = "Admin";
}
<div class="row g-3">
	<div class="col-lg-3 d-none d-lg-block">
		@await Html.PartialAsync("_Sidebar")
	</div>

n    <div class="col-lg-9">
		<div class="d-flex justify-content-between align-items-center mb-3">
			<div>
				<h4 class="mb-0">Administration</h4>
				<div class="small text-muted">Manage users, view logs and run reports</div>
			</div>
			<div>
				<button class="btn btn-outline-primary me-2">System Logs</button>
				<button class="btn btn-primary">Invite User</button>
			</div>
		</div>

n        <div class="row g-3 mb-3">
			<div class="col-md-4">
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="small text-muted">Total Users</div>
						<div class="h4 fw-bold">482</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="small text-muted">Total Claims</div>
						<div class="h4 fw-bold">3,210</div>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="small text-muted">Pending Claims</div>
						<div class="h4 fw-bold">42</div>
					</div>
				</div>
			</div>
		</div>

n        <div class="row g-3 mb-3">
			<div class="col-lg-6">
				<div class="card shadow-sm">
					<div class="card-body">
						<h6>Users</h6>
						<div class="table-responsive">
							<table class="table">
								<thead class="table-light">
									<tr><th>User</th><th>Role</th><th>Status</th><th></th></tr>
								</thead>
								<tbody>
									<tr>
										<td>Jane Doe</td>
										<td>Customer</td>
										<td><span class="badge bg-success">Active</span></td>
										<td><button class="btn btn-sm btn-outline-secondary">Edit</button></td>
									</tr>
									<tr>
										<td>Sam Officer</td>
										<td>Claim Officer</td>
										<td><span class="badge bg-success">Active</span></td>
										<td><button class="btn btn-sm btn-outline-secondary">Edit</button></td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>

n            <div class="col-lg-6">
				<div class="card shadow-sm">
					<div class="card-body">
						<h6>Reports</h6>
						<canvas id="adminChart" height="180"></canvas>
					</div>
				</div>
			</div>
		</div>

n    </div>
</div>

@section Scripts {
	<script>
		// Dummy chart
		var ctx = document.getElementById('adminChart');
		if (ctx) {
			new Chart(ctx, {
				type: 'line',
				data: {
					labels: ['Jan','Feb','Mar','Apr','May','Jun'],
					datasets: [{
						label: 'Claims',
						data: [320, 400, 350, 420, 380, 410],
						borderColor: '#2563EB',
						backgroundColor: 'rgba(37,99,235,0.08)',
						tension: 0.3,
						fill: true
					}]
				},
				options: {
					plugins: { legend: { display: false } },
					scales: {
						y: { beginAtZero: true }
					}
				}
			});
		}
	</script>
}