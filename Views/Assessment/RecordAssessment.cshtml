@model MyProject.Models.AssessmentEntity
@{
    ViewBag.Title = "Record Assessment - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4" style="max-width:600px">
    <div class="mb-4">
        <a href="/Assessment/GetAssessmentDetails/@Model.ClaimId" class="text-decoration-none text-muted small"><i class="fa-solid fa-arrow-left me-1"></i>Back to Assessment</a>
        <h4 class="fw-bold mt-2"><i class="fa-solid fa-clipboard-check me-2 text-success"></i>Record Assessment</h4>
        <p class="text-muted small">Claim #CLM-@Model.ClaimId.ToString("D5") &bull; Assessment #@Model.AssessmentId</p>
    </div>

    @if (TempData["Error"] != null)
    { <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]</div> }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="RecordAssessment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="assessmentId" value="@Model.AssessmentId" />
                <input type="hidden" name="claimId" value="@Model.ClaimId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Assessed Damage Amount (USD) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" name="assessedAmount" value="@Model.AssessedAmount" min="0" step="0.01"
                               class="form-control" placeholder="0.00" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Assessment Remarks</label>
                    <textarea name="remarks" class="form-control" rows="4" placeholder="Describe findings, damage details, site conditions...">@Model.AssessmentRemarks</textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4"><i class="fa-solid fa-floppy-disk me-1"></i>Save Assessment</button>
                    <a href="/Assessment/GetAssessmentDetails/@Model.ClaimId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
