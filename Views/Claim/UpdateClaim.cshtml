@model MyProject.Models.ClaimEntity
@{
    ViewBag.Title = "Update Claim - DriveSure";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var policies = ViewBag.Policies as List<MyProject.Models.Policy> ?? new();
}

<div class="container py-4" style="max-width:720px">
    <div class="mb-4">
        <a href="/Claim/GetClaimDetails/@Model.ClaimId" class="text-decoration-none text-muted small"><i class="fa-solid fa-arrow-left me-1"></i>Back to Claim</a>
        <h4 class="fw-bold mt-2"><i class="fa-solid fa-pen-to-square me-2 text-primary"></i>Update Claim #CLM-@Model.ClaimId.ToString("D5")</h4>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            { <div>@e.ErrorMessage</div> }
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="UpdateClaim" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ClaimId" />
                <input type="hidden" asp-for="CustomerId" />
                <input type="hidden" asp-for="PolicyId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Claim Type</label>
                    <select asp-for="ClaimType" class="form-select" required>
                        <option>Collision</option><option>Fire</option><option>Theft</option>
                        <option>Natural Disaster</option><option>Medical Emergency</option>
                        <option>Property Damage</option><option>Liability</option><option>Other</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Claim Amount (USD)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="ClaimAmount" type="number" min="1" step="0.01" class="form-control" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Status</label>
                    <select asp-for="ClaimStatus" class="form-select">
                        <option value="REGISTERED">Registered</option>
                        <option value="UNDER_REVIEW">Under Review</option>
                        <option value="APPROVED">Approved</option>
                        <option value="REJECTED">Rejected</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-floppy-disk me-1"></i>Save Changes</button>
                    <a href="/Claim/GetClaimDetails/@Model.ClaimId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
